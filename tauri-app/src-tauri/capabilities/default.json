{
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://127.0.0.1:8000/**" },
        { "url": "http://localhost:8000/**" }
      ]
    },
    "notification:default"
  ]
}
