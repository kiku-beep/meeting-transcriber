{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Transcriber",
  "version": "0.1.0",
  "identifier": "com.transcriber.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Transcriber - 会議文字起こし",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "center": true,
        "decorations": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Japanese", "English"]
      }
    },
    "shortDescription": "AI-powered real-time meeting transcription",
    "category": "Utility"
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
